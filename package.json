{
  "name": "corelode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CORELODE — a clean-room, browser-only remake of the 2004 mining classic",
  "scripts": {
    "dev": "vite",
    "build": "npm run atlas && tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "atlas": "node tools/gen-art.mjs && node tools/art/check-frames.mjs",
    "art:preview": "node tools/art/contact-sheet.mjs",
    "check:layering": "node tools/check-layering.mjs"
  },
  "dependencies": {
    "idb-keyval": "^6.2.1",
    "phaser": "^3.87.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^26.1.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
